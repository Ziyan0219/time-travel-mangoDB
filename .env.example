# ─────────────────────────────────────────────────────────────
# MongoDB Time Travel Pipeline — Configuration
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. Run:             python connect.py
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (REQUIRED)
# Local:       mongodb://localhost:27017
# Atlas:       mongodb+srv://<user>:<password>@<cluster>.mongodb.net
# Replica set: mongodb://host1:27017,host2:27017/?replicaSet=rs0
#
# NOTE: Change Streams require a replica set or Atlas cluster.
#       Standalone MongoDB does NOT support Change Streams.
MONGODB_URI=mongodb://localhost:27017

# Which database and collection to watch
DB_NAME=stocks
COLLECTION=prices

# ─── Field Mapping ────────────────────────────────────────────
# Tell the pipeline which fields in your documents map to what.
# Example document:  { "symbol": "AAPL", "last": 175.10, "vol": 1300000 }
# would use:         TICKER_FIELD=symbol   PRICE_FIELD=last   VOLUME_FIELD=vol

TICKER_FIELD=ticker
PRICE_FIELD=price
VOLUME_FIELD=volume

# ─── BigQuery Backend (optional) ──────────────────────────────
# Set USE_BIGQUERY=true to route all writes to real Google Cloud BigQuery
# instead of the local DuckDB simulator.
#
# SETUP:
#   1. Create a GCP project and enable the BigQuery API
#   2. Create a Service Account with roles:
#        - BigQuery Data Editor
#        - BigQuery Job User
#   3. Download the JSON key and set the path below
#
USE_BIGQUERY=false

# Path to your Service Account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Your GCP project ID (e.g. stock-time-travel-123456)
GCP_PROJECT=your-gcp-project-id

# BigQuery dataset and table names (created automatically if they don't exist)
BQ_DATASET=stocks
BQ_TABLE=stock_events
