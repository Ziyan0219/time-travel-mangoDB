# ─────────────────────────────────────────────────────────────
# MongoDB Time Travel Pipeline — Configuration
# ─────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values
# 3. Run:             python connect.py
# ─────────────────────────────────────────────────────────────

# MongoDB connection string (REQUIRED)
# Local:       mongodb://localhost:27017
# Atlas:       mongodb+srv://<user>:<password>@<cluster>.mongodb.net
# Replica set: mongodb://host1:27017,host2:27017/?replicaSet=rs0
#
# NOTE: Change Streams require a replica set or Atlas cluster.
#       Standalone MongoDB does NOT support Change Streams.
MONGODB_URI=mongodb://localhost:27017

# Which database and collection to watch
DB_NAME=stocks
COLLECTION=prices

# ─── Field Mapping ────────────────────────────────────────────
# Tell the pipeline which fields in your documents map to what.
# Example document:  { "symbol": "AAPL", "last": 175.10, "vol": 1300000 }
# would use:         TICKER_FIELD=symbol   PRICE_FIELD=last   VOLUME_FIELD=vol

TICKER_FIELD=ticker
PRICE_FIELD=price
VOLUME_FIELD=volume
